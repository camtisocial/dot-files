# CAVA config -- tuned to feed waybar's `custom/cava` module.
#
# The key bit is [output]: we emit RAW ASCII levels (0-7) to stdout, one frame
# per line, bars separated by ';'.  Waybar's exec pipes that through a small sed
# that maps each digit to a block glyph (▁▂▃▄▅▆▇█).  Without raw/stdout output
# cava falls back to its ncurses TUI and waybar gets nothing -- which is exactly
# why this never worked before.

[general]
# Frames per second.  Higher = smoother but more CPU.
framerate = 30
# Auto-reduce sensitivity when bars peak (1 = on).
autosens = 1
# Number of bars in the visualizer.
bars = 14
# Frequency band the bars cover.
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
# Pull audio straight from PipeWire; 'auto' = monitor of the default sink.
method = pipewire
source = auto

[output]
# RAW text to stdout is what makes the waybar module work.
method = raw
raw_target = /dev/stdout
data_format = ascii
# 0..7 -> 8 levels, matching the 8 block glyphs in the sed map.
ascii_max_range = 7
# ';' (59) between bars, newline (10) between frames -> sed strips the ';'.
bar_delimiter = 59
frame_delimiter = 10
# One combined channel (cleaner than mirrored stereo for a small bar).
channels = mono

[smoothing]
noise_reduction = 0.77
