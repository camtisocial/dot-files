# dunst — gruvbox theme matching the waybar bar / clock popups.
# Palette: bg #282828, fg #ebdbb2, gold #d79921, red #fb4934, gray #504945.
# Font: JetBrainsMono Nerd Font (same family the bar uses, so icon glyphs work).

[global]
    ### Display ###
    monitor = 0
    follow = mouse                 # show on whichever monitor has the pointer

    ### Geometry ###
    width = (0, 420)               # grow up to 420px wide
    height = (0, 300)
    origin = top-right             # tuck under the bar's right side, like the popups
    offset = (14, 48)
    notification_limit = 5
    scale = 0

    ### Progress bar (volume/brightness notifications) ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 160
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    ### Appearance ###
    transparency = 0               # opaque, to match the solid bar pills
    frame_width = 2
    frame_color = "#504945"
    corner_radius = 8              # rounded, like the 5-8px pill radius
    gap_size = 8                   # float each notification separately
    separator_height = 2
    separator_color = frame
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    sort = yes
    indicate_hidden = yes

    ### Text ###
    font = JetBrainsMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"       # bold summary, body underneath
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark"
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#282828"
    foreground = "#a89984"
    frame_color = "#665c54"
    highlight = "#83a598"
    timeout = 5

[urgency_normal]
    background = "#282828"
    foreground = "#ebdbb2"
    frame_color = "#d79921"
    highlight = "#d79921"
    timeout = 8

[urgency_critical]
    background = "#282828"
    foreground = "#fbf1c7"
    frame_color = "#fb4934"
    highlight = "#fb4934"
    timeout = 0

# Volume / brightness OSD (sent by waybar/osd.sh with appname "osd"). Quick to
# dismiss, gold progress bar, and kept out of the notification history so it
# doesn't bury real notifications with volume spam.
[osd]
    appname = "osd"
    timeout = 2
    history_ignore = yes
    frame_color = "#504945"
    highlight = "#d79921"
